# AI VideoCraft バックエンド 環境変数（本番サーバ用）
# このファイルを .env にコピーして値を設定するか、ホスティングの環境変数に登録します。

# --- ライセンス署名鍵（scripts/keygen.py init で生成）---
# 公開鍵は配布アプリにも埋め込む。秘密鍵はこのサーバだけに設定する。
AIVC_LICENSE_PUBLIC_KEY=
AIVC_LICENSE_PRIVATE_KEY=

# --- Stripe（方式B: 自動発行）---
AIVC_STRIPE_SECRET_KEY=sk_test_xxx
AIVC_STRIPE_WEBHOOK_SECRET=whsec_xxx
AIVC_STRIPE_PRICE_PERPETUAL=price_xxx        # 買い切り（一括, ¥2,980）
AIVC_STRIPE_PRICE_SUBSCRIPTION=price_xxx     # サブスク（月次, ¥380/月）
AIVC_BILLING_SUCCESS_URL=https://your-site/thanks
AIVC_BILLING_CANCEL_URL=https://your-site/cancel

# --- 購入通知メール（任意・SMTP）---
AIVC_NOTIFY_EMAIL=nakadzho777@gmail.com
# AIVC_SMTP_HOST=smtp.gmail.com
# AIVC_SMTP_USER=you@gmail.com
# AIVC_SMTP_PASSWORD=app_password

# --- 開発者機能（本番では未設定=無効のまま）---
# AIVC_DEV_MODE=1

# --- データ保存先（Docker では /data にボリュームをマウント）---
# AIVC_DB_PATH=/data/videocraft.sqlite3
